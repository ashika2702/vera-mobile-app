generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id                          String                       @id @default(cuid())
  phone                       String                       @unique
  name                        String?
  razorpayCustomerId          String?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  cansInHand                  Int                          @default(0)
  depositWalletBalance        Float                        @default(0)
  active                      Boolean                      @default(true)
  addresses                   Address[]
  cartItems                   CartItem[]
  paymentMethods              CustomerPaymentMethod[]
  productPrices               CustomerProductPrice[]
  depositRefundRequests       DepositRefundRequest[]
  depositVerificationRequests DepositVerificationRequest[]
  orders                      Order[]
  returnCanRequests           ReturnCanRequest[]
  sessions                    UserSession[]
  walletTransactions          WalletTransaction[]
}

model UserSession {
  id         String   @id @default(cuid())
  customerId String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  pushToken  String?
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([customerId])
}

model WalletTransaction {
  id            String   @id @default(cuid())
  customerId    String
  amount        Float
  type          String
  referenceType String
  referenceId   String?
  description   String?
  createdAt     DateTime @default(now())
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([createdAt])
}

model Address {
  id                    String                 @id @default(cuid())
  customerId            String
  line1                 String
  line2                 String?
  area                  String
  city                  String
  pincode               String
  landmark              String?
  isDefault             Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  contactName           String?
  contactPhone          String?
  nickname              String?
  active                Boolean                @default(true)
  latitude              Float?
  longitude             Float?
  customer              Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  depositRefundRequests DepositRefundRequest[]
  orders                Order[]
  returnRequests        ReturnCanRequest[]

  @@index([pincode])
  @@index([area])
}

model Order {
  id                 String             @id @default(cuid())
  customerId         String
  addressId          String
  quantity           Int
  deliveryDate       DateTime
  deliverySlot       String
  status             OrderStatus        @default(PENDING)
  paymentStatus      PaymentStatus      @default(PENDING)
  paymentMethod      PaymentMethod
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  amount             Int
  additionalQuantity Int?
  originalQuantity   Int?
  paymentInstrument  String?
  productId          String?
  depositAmount      Int                @default(0)
  orderNumber        String?            @unique
  isQrPayment        Boolean            @default(false)
  address            Address            @relation(fields: [addressId], references: [id])
  customer           Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product            Product?           @relation(fields: [productId], references: [id])
  activityLogs       OrderActivityLog[]
  items              OrderItem[]
  payments           Payment[]
  routeOrders        RouteOrder[]

  @@index([createdAt])
  @@index([deliveryDate])
  @@index([status])
  @@index([paymentStatus])
  @@index([customerId])
  @@index([productId])
}

model OrderItem {
  id                   String  @id @default(cuid())
  orderId              String
  productId            String
  quantity             Int
  price                Float
  gst                  Float   @default(5.0)
  returnQuantity       Int     @default(0)
  actualReturnQuantity Int?
  order                Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product              Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  provider          String
  providerOrderId   String?
  providerPaymentId String?       @unique
  amount            Int
  status            PaymentStatus @default(PENDING)
  method            PaymentMethod
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  routeOrderId      String?
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  routeOrder        RouteOrder?   @relation(fields: [routeOrderId], references: [id])

  @@index([orderId])
}

model DeliveryBoy {
  id                 String             @id @default(cuid())
  name               String
  phone              String             @unique
  active             Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  onLeave            Boolean            @default(false)
  adminId            String?
  admin              Admin?             @relation(fields: [adminId], references: [id])
  returnRequests     ReturnCanRequest[]
  routes             Route[]
  currentStaffRoutes ServiceRoute[]     @relation("CurrentStaff")

  @@index([active, onLeave])
}

model ReturnCanRequest {
  id                String              @id @default(cuid())
  customerId        String
  quantity          Int
  status            ReturnRequestStatus @default(REQUESTED)
  refundAmount      Float
  refundMethod      String              @default("ONLINE")
  upiId             String?
  accountNumber     String?
  ifscCode          String?
  bankName          String?
  adminId           String?
  deliveryPartnerId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  approvedAt        DateTime?
  collectedAt       DateTime?
  addressId         String?
  address           Address?            @relation(fields: [addressId], references: [id])
  customer          Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deliveryPartner   DeliveryBoy?        @relation(fields: [deliveryPartnerId], references: [id])

  @@index([customerId])
  @@index([status])
}

model DepositRefundRequest {
  id            String              @id @default(cuid())
  customerId    String
  amount        Float
  status        DepositRefundStatus @default(REQUESTED)
  adminNote     String?
  upiId         String?
  accountNumber String?
  ifscCode      String?
  bankName      String?
  transactionId String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  approvedAt    DateTime?
  rejectedAt    DateTime?
  quantity      Int?
  addressId     String?
  date          DateTime            @default(now())
  collected     Boolean             @default(false)
  collectedAt   DateTime?
  address       Address?            @relation(fields: [addressId], references: [id])
  customer      Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([status])
}

model RouteShiftLog {
  id               String          @id @default(cuid())
  routeId          String
  action           ShiftActionType
  triggeredBy      String
  timestamp        DateTime        @default(now())
  previousSequence Json?
  newSequence      Json?
  route            Route           @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
  @@index([action])
  @@index([timestamp])
}

model ServiceRoute {
  id                   String        @id @default(cuid())
  name                 String        @unique
  description          String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  currentDeliveryBoyId String?
  dailyRoutes          Route[]
  serviceAreas         ServiceArea[]
  currentDeliveryBoy   DeliveryBoy?  @relation("CurrentStaff", fields: [currentDeliveryBoyId], references: [id])

  @@index([currentDeliveryBoyId])
}

model Route {
  id              String          @id @default(cuid())
  date            DateTime
  token           String?         @unique
  tokenExpiresAt  DateTime?
  deliveryBoyId   String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  serviceRouteId  String
  isSubmitted     Boolean         @default(false)
  submittedAt     DateTime?
  isAutoOptimized Boolean         @default(false)
  shiftStatus     ShiftStatus     @default(PENDING)
  deliveryBoy     DeliveryBoy     @relation(fields: [deliveryBoyId], references: [id])
  serviceRoute    ServiceRoute    @relation(fields: [serviceRouteId], references: [id])
  routeOrders     RouteOrder[]
  shiftLogs       RouteShiftLog[]
  tokenLogs       RouteTokenLog[]

  @@unique([serviceRouteId, date], map: "unique_daily_route")
  @@index([date])
  @@index([deliveryBoyId])
  @@index([serviceRouteId])
}

model RouteTokenLog {
  id          String   @id @default(cuid())
  routeId     String
  token       String
  generatedAt DateTime @default(now())
  action      String   @default("GENERATED")
  timestamp   DateTime @default(now())
  route       Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
}

model RouteOrder {
  id                 String         @id @default(cuid())
  routeId            String
  orderId            String
  deliveryStatus     DeliveryStatus @default(PENDING)
  notDeliveredReason String?
  codCollected       Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  sequence           Int            @default(0)
  payments           Payment[]
  order              Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  route              Route          @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([orderId, routeId])
  @@index([routeId])
  @@index([orderId])
  @@index([deliveryStatus])
  @@index([orderId, deliveryStatus])
}

model CustomerPaymentMethod {
  id                    String   @id @default(cuid())
  customerId            String
  type                  String
  details               String
  isDefault             Boolean  @default(false)
  verified              Boolean  @default(false)
  stripePaymentMethodId String?
  razorpayTokenId       String?
  cardBrand             String?
  cardLast4             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  customer              Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([razorpayTokenId])
}

model OtpSession {
  id        String   @id @default(cuid())
  phone     String
  otpHash   String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Product {
  id                          String                       @id @default(cuid())
  name                        String
  description                 String?
  price                       Float
  image                       String?
  unit                        String                       @default("")
  inStock                     Boolean                      @default(true)
  active                      Boolean                      @default(true)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  gst                         Float                        @default(5.0)
  depositAmount               Float                        @default(0)
  isCustomPrice               Boolean                      @default(false)
  cartItems                   CartItem[]
  customerPrices              CustomerProductPrice[]
  depositVerificationRequests DepositVerificationRequest[]
  orders                      Order[]
  orderItems                  OrderItem[]

  @@index([active])
  @@index([active, inStock])
}

model CartItem {
  id             String   @id @default(cuid())
  customerId     String
  productId      String
  quantity       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  returnQuantity Int      @default(0)
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([customerId])
}

model CustomerProductPrice {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([customerId])
  @@index([productId])
}

model Admin {
  id                  String        @id @default(cuid())
  email               String        @unique
  username            String        @unique
  passwordHash        String
  name                String?
  active              Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deliveryBoyProfiles DeliveryBoy[]
  roles               AdminRole[]   @relation("AdminToAdminRole")

  @@index([email])
  @@index([username])
}

model AdminRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admins      Admin[]  @relation("AdminToAdminRole")
}

model ServiceArea {
  id             String        @id @default(cuid())
  pincode        String        @unique
  areaName       String        @unique
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  serviceRouteId String?
  serviceRoute   ServiceRoute? @relation(fields: [serviceRouteId], references: [id])

  @@index([pincode])
  @@index([serviceRouteId])
}

model SystemConfig {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupportContact {
  id        String   @id @default(cuid())
  type      String
  label     String
  value     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model DepositVerificationRequest {
  id         String                    @id @default(cuid())
  customerId String
  productId  String
  quantity   Int
  status     DepositVerificationStatus @default(PENDING)
  adminNote  String?
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  approvedAt DateTime?
  rejectedAt DateTime?
  customer   Customer                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product    Product                   @relation(fields: [productId], references: [id])

  @@index([customerId])
  @@index([productId])
  @@index([status])
}

model NotDeliveredReason {
  id                 String   @id @default(cuid())
  reason             String   @unique
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  autoReassign       Boolean  @default(false)
  hideFromExceptions Boolean  @default(false)

  @@index([isActive])
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model OrderActivityLog {
  id          String   @id @default(cuid())
  orderId     String
  action      String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorType   String
  actorName   String?
  entity      String
  entityId    String
  action      String
  oldData     Json?
  newData     Json?
  description String?
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId])
  @@index([createdAt])
}

enum DepositRefundStatus {
  REQUESTED
  PAID
  REJECTED
}

enum ReturnRequestStatus {
  REQUESTED
  APPROVED
  ASSIGNED
  COLLECTED
  REFUNDED
  REJECTED
}

enum ShiftStatus {
  PENDING
  IN_PROGRESS
  PAUSED
  COMPLETED
}

enum ShiftActionType {
  START
  PAUSE
  RESUME
  END
  OPTIMIZE
}

enum DepositVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  NOT_DELIVERED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  COD
}

enum PaymentMethod {
  ONLINE
  COD
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  NOT_DELIVERED
}
