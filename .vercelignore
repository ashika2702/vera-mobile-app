# Vercel ignore file
# Files and directories to exclude from deployment

# Environment files (should be set in Vercel dashboard)
.env
.env.local
.env.*.local

# Development files
node_modules
.next
.vercel

# Documentation
*.md
!README.md

# IDE files
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage
.nyc_output

# Prisma
# Note: Keep prisma/ directory but ignore generated client in node_modules

